{
  "name": "@netcero/interview-template",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "nx run-many --targets=serve --projects=api,web --parallel",
    "dev:api": "nx serve api",
    "dev:web": "nx serve web",
    "build": "nx run-many --targets=build --all",
    "seed": "ts-node -r tsconfig-paths/register -P apps/api/tsconfig.app.json apps/api/src/database/seeds/seed.ts",
    "db:up": "docker compose -f docker/docker-compose.yaml up -d",
    "db:down": "docker compose -f docker/docker-compose.yaml down",
    "db:reset": "docker compose -f docker/docker-compose.yaml down -v && docker compose -f docker/docker-compose.yaml up -d"
  },
  "private": true,
  "devDependencies": {
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/devkit": "22.6.1",
    "@nx/eslint": "^22.6.1",
    "@nx/js": "22.6.1",
    "@nx/nest": "^22.6.1",
    "@nx/node": "22.6.1",
    "@nx/playwright": "22.6.1",
    "@nx/react": "^22.6.1",
    "@nx/vite": "^22.6.1",
    "@nx/web": "22.6.1",
    "@nx/webpack": "^22.6.1",
    "@playwright/test": "^1.36.0",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@types/node": "20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "~4.0.0",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "nx": "22.6.1",
    "prettier": "^2.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "vite": "^7.0.0",
    "vitest": "~4.0.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "axios": "^1.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "6.30.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  }
}
